# Maintainer: AmberHTML Contributors <noreply@github.com>
# AUR package for the AmberHTML CLI (Plans.md 14.6). Builds `amber` from the
# tagged GitHub source tarball with cargo. Submit to the AUR as `amber-html`.
# At release: set `sha256sums` to the tarball hash (or keep 'SKIP' for -git).
pkgname=amber-html
pkgver=0.1.0
pkgrel=1
pkgdesc="Local-first web-page capture engine (Markdown, HTML, MHTML, WARC/WACZ, PDF, screenshot)"
arch=('x86_64' 'aarch64')
url="https://github.com/afeique/amber-html"
license=('MIT' 'Apache')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/afeique/amber-html/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')

prepare() {
  cd "amber-html-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "amber-html-$pkgver"
  export RUSTUP_TOOLCHAIN=stable CARGO_TARGET_DIR=target
  cargo build --frozen --release -p amber-cli
}

package() {
  cd "amber-html-$pkgver"
  install -Dm755 "target/release/amber" "$pkgdir/usr/bin/amber"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
  install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
}
