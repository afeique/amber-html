{
  "name": "amber-html",
  "version": "0.0.0",
  "description": "Node.js bindings for AmberHTML — local-first web-page capture.",
  "license": "MIT OR Apache-2.0",
  "main": "index.js",
  "files": ["index.js", "*.node"],
  "napi": {
    "binaryName": "amber",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "test": "node __test__/smoke.test.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  }
}
